# DriveWiki Environment Variables
# Copy to .env and fill in your values

# Database (Cloud SQL PostgreSQL 16)
DATABASE_URL="postgresql://user:password@localhost:5432/drivewiki?schema=public"

# Google OAuth 2.0
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Google Workspace Domain (restrict login to this domain)
GOOGLE_WORKSPACE_DOMAIN="your-company.com"

# JWT Configuration
JWT_SECRET="your-jwt-secret-at-least-32-chars"
JWT_EXPIRY="8h"

# HMAC Audit Logging
HMAC_SECRET="your-hmac-secret-at-least-32-chars"

# Vertex AI (Gemini)
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_REGION="asia-southeast1"
VERTEX_AI_MODEL="gemini-2.5-pro"

# Redis (Cloud Memorystore)
REDIS_URL="redis://localhost:6379"

# Google Cloud Storage
GCS_BUCKET_NAME="drivewiki-storage"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
