# DriveWiki Environment Variables
# Copy to .env and fill in your values

# Database (Cloud SQL PostgreSQL 16)
DATABASE_URL="postgresql://user:password@localhost:5432/drivewiki?schema=public"

# Google OAuth 2.0
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Auth Session (jose JWT, HS256)
AUTH_SECRET="your-auth-secret-at-least-32-chars"

# Refresh Token Encryption (AES-256-GCM, base64-encoded 32-byte key)
# Generate with: openssl rand -base64 32
DW_REFRESH_TOKEN_KEY="your-base64-encoded-32-byte-key"

# Domain Allowlist (comma-separated, empty = allow all in dev)
ALLOWED_DOMAINS="your-company.com"

# Application URL (used for OAuth callbacks)
APP_URL="http://localhost:3000"

# HMAC Audit Logging
HMAC_SECRET="your-hmac-secret-at-least-32-chars"

# Vertex AI (Gemini)
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_REGION="asia-southeast1"
VERTEX_AI_MODEL="gemini-2.5-pro"

# Redis (Cloud Memorystore)
REDIS_URL="redis://localhost:6379"

# Google Cloud Storage
GCS_BUCKET_NAME="drivewiki-storage"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
